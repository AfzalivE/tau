#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
TAU_SKILLS_DIR="${ROOT}/skills"

AGENTS_DIR="${AGENTS_DIR:-${HOME}/.agents}"
AGENTS_INSTRUCTIONS_FILE="${AGENTS_DIR}/AGENTS.md"
AGENTS_SKILLS_DIR="${AGENTS_DIR}/skills"

CODEX_INSTRUCTIONS_FILE="${HOME}/.codex/AGENTS.md"
CODEX_SKILLS_TAU_DIR="${HOME}/.codex/skills/tau"
CLAUDE_INSTRUCTIONS_FILE="${HOME}/.claude/CLAUDE.md"
CLAUDE_SKILLS_DIR="${HOME}/.claude/skills"
CLAUDE_MARKETPLACE_NAME="afzal-tau-local"
CLAUDE_PLUGIN_ID="tau-afzal@${CLAUDE_MARKETPLACE_NAME}"

SYNC_CODEX=0
SYNC_CLAUDE=0
SYNC_TARGETS_SET=0
PRUNE=0
YES=0

usage() {
  cat <<EOF
Set up Tau-managed files for Codex and Claude.

Usage:
  setup [--codex] [--claude] [--prune] [--yes]

Options:
  --codex   Set up only Codex-managed files
  --claude  Set up only Claude-managed files
  --prune   Remove legacy Claude skill symlinks for skills present in this checkout
  -y, --yes Approve confirmation-gated Codex skills and Claude plugin steps

Environment:
  AGENTS_DIR  Override the personal agent config directory (default: ~/.agents)

Notes:
  - If no agent flag is provided, set up Codex and Claude.
  - This script does not manage ~/.agents/skills.
  - Codex gets ~/.codex/skills/tau as an optional symlink to this checkout's skills/ directory.
  - Claude uses this checkout's Claude marketplace/plugin and does not get skill symlinks.
  - Confirmation is requested before creating ~/.codex/skills/tau or running Claude plugin commands.
  - ~/.agents/AGENTS.md remains the source of truth for personal instructions.
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --codex)
        SYNC_CODEX=1
        SYNC_TARGETS_SET=1
        shift
        ;;
      --claude)
        SYNC_CLAUDE=1
        SYNC_TARGETS_SET=1
        shift
        ;;
      --prune)
        PRUNE=1
        shift
        ;;
      -y | --yes)
        YES=1
        shift
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      *)
        echo "error: unknown argument: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done
}

apply_default_targets() {
  if [[ "${SYNC_TARGETS_SET}" -eq 0 ]]; then
    SYNC_CODEX=1
    SYNC_CLAUDE=1
  fi
}

require_source() {
  local path="$1"
  local kind="$2"

  if [[ "${kind}" == "file" && ! -f "${path}" ]]; then
    echo "error: missing file: ${path}" >&2
    exit 1
  fi

  if [[ "${kind}" == "dir" && ! -d "${path}" ]]; then
    echo "error: missing directory: ${path}" >&2
    exit 1
  fi
}

confirm_step() {
  local prompt="$1"

  if [[ "${YES}" -eq 1 ]]; then
    return 0
  fi

  if [[ ! -t 0 ]]; then
    printf 'Skipping: %s (confirmation required; rerun interactively or pass --yes)\n' "${prompt}" >&2
    return 1
  fi

  local reply
  if ! read -r -p "${prompt} [y/N] " reply; then
    printf '\nSkipping: %s\n' "${prompt}" >&2
    return 1
  fi

  case "${reply}" in
    [Yy] | [Yy][Ee][Ss])
      return 0
      ;;
    *)
      printf 'Skipped: %s\n' "${prompt}"
      return 1
      ;;
  esac
}

link_path() {
  local source="$1"
  local target="$2"

  mkdir -p "$(dirname "${target}")"

  if [[ -L "${target}" ]]; then
    local current
    current="$(readlink "${target}")"
    if [[ "${current}" == "${source}" ]]; then
      return 0
    fi
    rm "${target}"
  elif [[ -e "${target}" ]]; then
    if [[ -f "${source}" && -f "${target}" ]] && cmp -s "${source}" "${target}"; then
      rm "${target}"
    else
      local backup="${target}.bak.$(date +%Y%m%d%H%M%S)"
      mv "${target}" "${backup}"
      printf 'Backed up %s to %s\n' "${target}" "${backup}"
    fi
  fi

  ln -s "${source}" "${target}"
  printf 'Linked %s -> %s\n' "${target}" "${source}"
}

link_path_confirmed() {
  local source="$1"
  local target="$2"
  local prompt="$3"

  if [[ -L "${target}" ]]; then
    local current
    current="$(readlink "${target}")"
    if [[ "${current}" == "${source}" ]]; then
      return 0
    fi
  fi

  if confirm_step "${prompt}"; then
    link_path "${source}" "${target}"
  fi
}

run_confirmed() {
  local prompt="$1"
  shift

  if confirm_step "${prompt}"; then
    printf 'Running:'
    printf ' %q' "$@"
    printf '\n'
    "$@"
  fi
}

prune_claude_skills() {
  [[ "${PRUNE}" -eq 1 ]] || return 0
  [[ -d "${CLAUDE_SKILLS_DIR}" ]] || return 0

  local skill_dir
  for skill_dir in "${TAU_SKILLS_DIR}"/*; do
    [[ -d "${skill_dir}" ]] || continue

    local skill_name
    skill_name="$(basename "${skill_dir}")"
    [[ "${skill_name}" == .* ]] && continue

    local target="${CLAUDE_SKILLS_DIR}/${skill_name}"
    [[ -L "${target}" ]] || continue

    local current
    current="$(readlink "${target}")"
    case "${current}" in
      "${AGENTS_SKILLS_DIR}/${skill_name}" | "${TAU_SKILLS_DIR}/${skill_name}")
        rm "${target}"
        printf 'Removed legacy Claude skill symlink %s\n' "${target}"
        ;;
    esac
  done
}

setup_codex() {
  [[ "${SYNC_CODEX}" -eq 1 ]] || return 0
  link_path "${AGENTS_INSTRUCTIONS_FILE}" "${CODEX_INSTRUCTIONS_FILE}"
  link_path_confirmed \
    "${TAU_SKILLS_DIR}" \
    "${CODEX_SKILLS_TAU_DIR}" \
    "Link ${CODEX_SKILLS_TAU_DIR} to ${TAU_SKILLS_DIR}?"
}

setup_claude_plugin() {
  if ! command -v claude >/dev/null 2>&1; then
    echo "warning: claude command not found; skipping Claude marketplace/plugin setup" >&2
    return 0
  fi

  run_confirmed \
    "Add Tau Claude marketplace with 'claude plugin marketplace add --scope user ${ROOT}'?" \
    claude plugin marketplace add --scope user "${ROOT}"
  run_confirmed \
    "Install Tau Claude plugin with 'claude plugin install --scope user ${CLAUDE_PLUGIN_ID}'?" \
    claude plugin install --scope user "${CLAUDE_PLUGIN_ID}"
}

setup_claude() {
  [[ "${SYNC_CLAUDE}" -eq 1 ]] || return 0

  link_path "${AGENTS_INSTRUCTIONS_FILE}" "${CLAUDE_INSTRUCTIONS_FILE}"
  prune_claude_skills
  setup_claude_plugin
}

main() {
  parse_args "$@"
  apply_default_targets

  require_source "${AGENTS_INSTRUCTIONS_FILE}" file
  require_source "${TAU_SKILLS_DIR}" dir

  setup_codex
  setup_claude
}

main "$@"
