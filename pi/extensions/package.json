{
  "name": "pi-extensions",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "format": "git ls-files -z --cached --others --exclude-standard -- ':(glob)**/*.ts' | xargs -0 oxfmt --write",
    "format:check": "git ls-files -z --cached --others --exclude-standard -- ':(glob)**/*.ts' | xargs -0 oxfmt --check"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "0.65.0",
    "@mariozechner/pi-coding-agent": "0.65.0",
    "@mariozechner/pi-tui": "0.65.0",
    "@sinclair/typebox": "0.34.49",
    "@types/node": "24.12.0",
    "oxfmt": "^0.44.0",
    "typescript": "5.9.3"
  }
}
